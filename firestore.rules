rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: Check if user is authenticated with @alpha.school email
    function isAlphaSchoolUser() {
      return request.auth != null &&
             request.auth.token.email.matches('.*@alpha\\.school$');
    }

    // Helper function: Check if user is Sebastian (admin)
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'sebastian.sarmiento@alpha.school';
    }

    // GEM Prompts Collection
    match /gemPrompts/{promptId} {
      allow read: if isAlphaSchoolUser();

      // ✅ SECURITY: Field validation for GEM prompts
      // Any @alpha.school user can create prompts
      allow create: if isAlphaSchoolUser() &&
        request.resource.data.searchQuery is string &&
        request.resource.data.searchQuery.size() > 0 &&
        request.resource.data.searchQuery.size() <= 500 &&
        request.resource.data.promptContent is string &&
        request.resource.data.promptContent.size() > 0 &&
        request.resource.data.createdAt is timestamp;

      // Only admin can update/delete
      allow update, delete: if isAdmin();
    }

    // Research Repository Collection
    match /researchItems/{itemId} {
      allow read: if isAlphaSchoolUser();
      allow create, update, delete: if isAdmin();
    }

    // Decision Logs Collection
    match /decisionLogs/{logId} {
      allow read: if isAlphaSchoolUser();
      allow create, update, delete: if isAdmin();
    }

    // Scrollytelling Reports Collection
    match /scrollytellingReports/{reportId} {
      allow read: if isAlphaSchoolUser();
      allow create, update, delete: if isAdmin();
    }

    // Stakeholder Approvals Collection
    match /stakeholderApprovals/{approvalId} {
      allow read: if isAlphaSchoolUser();
      allow create, update, delete: if isAdmin();
    }

    // Investigations Collection
    match /investigations/{investigationId} {
      allow read: if isAlphaSchoolUser();

      // ✅ SECURITY: Field validation for investigations
      allow create: if isAdmin() &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.title.size() <= 500 &&
        request.resource.data.author is string &&
        request.resource.data.author.size() > 0 &&
        request.resource.data.author.size() <= 200;

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Research Collections (Planning)
    match /researchCollections/{collectionId} {
      allow read: if isAlphaSchoolUser();
      allow create, update, delete: if isAdmin();
    }

    // Raw Research Results (Gemini/Perplexity outputs)
    match /rawResearchResults/{resultId} {
      allow read: if isAlphaSchoolUser();

      // ✅ SECURITY: Strict field validation for create
      allow create: if isAdmin() &&
        // Required fields
        request.resource.data.keys().hasAll(['searchQuery', 'createdAt', 'createdBy']) &&
        request.resource.data.searchQuery is string &&
        request.resource.data.searchQuery.size() > 0 &&
        request.resource.data.searchQuery.size() <= 1000 &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.createdBy is string &&
        request.resource.data.createdBy.size() > 0 &&
        request.resource.data.createdBy.size() <= 200 &&
        // Optional fields validation
        (!request.resource.data.keys().hasAny(['geminiResults']) ||
         (request.resource.data.geminiResults is string && request.resource.data.geminiResults.size() <= 500000)) &&
        (!request.resource.data.keys().hasAny(['perplexityResults']) ||
         (request.resource.data.perplexityResults is string && request.resource.data.perplexityResults.size() <= 500000)) &&
        // Ensure at least one result is provided
        (request.resource.data.keys().hasAny(['geminiResults', 'perplexityResults']));

      // ✅ SECURITY: Only allow updating specific fields
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['searchQuery', 'geminiResults', 'perplexityResults']
        );

      allow delete: if isAdmin();
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
